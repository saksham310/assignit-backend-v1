# Server Configuration
PORT=8080

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration (Prisma will read from DATABASE_URL)
DATABASE_URL=postgresql://username:password@localhost:5432/assignit

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:5173,https://yourapp.com,https://www.yourapp.com
CORS_ORIGINS=http://localhost:5173

# Email/SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=AssignIt

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
